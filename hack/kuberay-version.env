# Single source of truth for the KubeRay / Kubernetes versions used by the test
# tiers. Both the envtest CRD fetch (tier 2) and the kind/helm e2e targets
# (tier 5) read KUBERAY_VERSION from this file so the two tiers stay
# behaviorally aligned (testing-strategy §3 "Version pinning").
#
# Sourced by the Makefile; safe to `source` from a POSIX shell (no spaces, no
# expansion). Keep it value-only.

# KubeRay operator + CRD bundle version. Drives:
#   - the CRD yamls fetched into test/crds/ for envtest (tier 2)
#   - the kind kubeconfig + Helm chart install for e2e (tier 5)
KUBERAY_VERSION=v1.6.1

# Kubernetes control-plane (kube-apiserver + etcd) version that setup-envtest
# fetches for tier 2. 1.32.x is within KubeRay v1.6.1's supported range and the
# CRD bundle applies cleanly against it. Must be a version setup-envtest can
# download for this platform.
ENVTEST_K8S_VERSION=1.32.0
